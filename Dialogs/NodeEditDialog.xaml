<Window x:Class="NaiwaProxy.Dialogs.NodeEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="节点编辑"
        Height="640" Width="760" MinHeight="560" MinWidth="680"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6FA"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        FontSize="14"
        ResizeMode="CanResize">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Panel3Brush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="LineBrush" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#64748B"/>
        <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#BFDBFE" Offset="0"/>
            <GradientStop Color="#60A5FA" Offset="1"/>
        </LinearGradientBrush>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource Panel3Brush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="{StaticResource AccentGradientBrush}"/>
            <Setter Property="BorderBrush" Value="#93C5FD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Margin="20" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="16" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="节点编辑" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="86"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="86"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="协议" Foreground="{StaticResource MutedBrush}" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,10"/>
                <ComboBox x:Name="ProtocolBox" Grid.Row="0" Grid.Column="1" Margin="0,0,12,10">
                    <ComboBoxItem Content="vmess"/>
                    <ComboBoxItem Content="vless"/>
                    <ComboBoxItem Content="trojan"/>
                    <ComboBoxItem Content="shadowsocks"/>
                    <ComboBoxItem Content="socks"/>
                    <ComboBoxItem Content="http"/>
                </ComboBox>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="名称" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,10"/>
                <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="3" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="地址" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,10"/>
                <TextBox x:Name="AddressBox" Grid.Row="1" Grid.Column="1" Margin="0,0,12,10"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="端口" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,10"/>
                <TextBox x:Name="PortBox" Grid.Row="1" Grid.Column="3" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="UUID / 用户" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,10"/>
                <TextBox x:Name="UuidBox" Grid.Row="2" Grid.Column="1" Margin="0,0,12,10"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="密码" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,10"/>
                <TextBox x:Name="PasswordBox" Grid.Row="2" Grid.Column="3" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Alter ID" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,10"/>
                <TextBox x:Name="AlterIdBox" Grid.Row="3" Grid.Column="1" Margin="0,0,12,10"/>
                <TextBlock Grid.Row="3" Grid.Column="2" Text="Security" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,10"/>
                <ComboBox x:Name="SecurityBox" Grid.Row="3" Grid.Column="3" Margin="0,0,0,10">
                    <ComboBoxItem Content="auto"/>
                    <ComboBoxItem Content="none"/>
                    <ComboBoxItem Content="aes-128-gcm"/>
                    <ComboBoxItem Content="aes-256-gcm"/>
                    <ComboBoxItem Content="chacha20-poly1305"/>
                    <ComboBoxItem Content="2022-blake3-aes-128-gcm"/>
                    <ComboBoxItem Content="2022-blake3-aes-256-gcm"/>
                </ComboBox>
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Network" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,10"/>
                <ComboBox x:Name="NetworkBox" Grid.Row="4" Grid.Column="1" Margin="0,0,12,10">
                    <ComboBoxItem Content="tcp"/>
                    <ComboBoxItem Content="ws"/>
                    <ComboBoxItem Content="grpc"/>
                </ComboBox>
                <TextBlock Grid.Row="4" Grid.Column="2" Text="TLS" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,10"/>
                <ComboBox x:Name="TlsBox" Grid.Row="4" Grid.Column="3" Margin="0,0,0,10">
                    <ComboBoxItem Content="none"/>
                    <ComboBoxItem Content="tls"/>
                </ComboBox>
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Host" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,10"/>
                <TextBox x:Name="HostBox" Grid.Row="5" Grid.Column="1" Margin="0,0,12,10"/>
                <TextBlock Grid.Row="5" Grid.Column="2" Text="SNI" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,10"/>
                <TextBox x:Name="SniBox" Grid.Row="5" Grid.Column="3" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Path" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="PathBox" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3"/>
                <TextBlock Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="3" Text="VMess/VLESS 使用 UUID；Trojan/Shadowsocks 使用密码；SOCKS/HTTP 可填写用户和密码。" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,10,0,0"/>
            </Grid>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="取消" Style="{StaticResource DarkButtonStyle}" Margin="0,0,8,0" IsCancel="True"/>
                <Button Content="保存节点" Style="{StaticResource PrimaryButtonStyle}" IsDefault="True" Click="SaveButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
