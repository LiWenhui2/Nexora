<Window x:Class="NaiwaProxy.Dialogs.ImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="节点导入"
        Height="360" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6FA"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        ResizeMode="NoResize">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Panel3Brush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="LineBrush" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#64748B"/>
        <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FACC15" Offset="0"/>
            <GradientStop Color="#F59E0B" Offset="1"/>
        </LinearGradientBrush>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource Panel3Brush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="{StaticResource AccentGradientBrush}"/>
            <Setter Property="BorderBrush" Value="#FBBF24"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Margin="20" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="16" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="节点导入" FontSize="16" FontWeight="Bold"/>
                <TextBlock Text="粘贴 vmess:// 分享链接，或输入 http(s) 节点订阅地址" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,6,0,0"/>
            </StackPanel>
            <TextBox x:Name="ImportBox" Grid.Row="1" MinHeight="160"/>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="取消" Style="{StaticResource DarkButtonStyle}" Margin="0,0,8,0" IsCancel="True"/>
                <Button x:Name="ImportButton" Content="导入" Style="{StaticResource PrimaryButtonStyle}" IsDefault="True" Click="ImportButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
