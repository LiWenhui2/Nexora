<Window x:Class="NaiwaProxy.Dialogs.DurationPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="自定义刷新间隔"
        Height="220" Width="420"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6FA"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        FontSize="14"
        ResizeMode="NoResize">
    <Border Margin="20" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Grid.Row="1" Text="请输入自动刷新的间隔（分钟）" Foreground="#64748B" Margin="0,0,0,10"/>
            <DockPanel Grid.Row="2" LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="取消" Width="88" Height="38" Margin="0,0,8,0" IsCancel="True"/>
                    <Button Content="确定" Width="88" Height="38" IsDefault="True" Click="SaveButton_Click"/>
                </StackPanel>
                <TextBox x:Name="MinutesBox" Height="38" VerticalContentAlignment="Center" Padding="10,0"/>
            </DockPanel>
        </Grid>
    </Border>
</Window>
