<Window x:Class="NaiwaProxy.Dialogs.UpdateConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="发现新版本"
        Height="520" Width="560" MinHeight="400" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6FA"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        FontSize="14"
        ResizeMode="CanResize">
    <Border Margin="20" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock x:Name="SummaryText" Grid.Row="1" Foreground="#64748B" TextWrapping="Wrap" Margin="0,0,0,12"/>
            <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,16">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <TextBlock x:Name="ReleaseNotesText" TextWrapping="Wrap" Foreground="#0F172A" LineHeight="22"/>
                </ScrollViewer>
            </Border>
            <TextBlock x:Name="InstallerText" Grid.Row="3" Foreground="#64748B" TextWrapping="Wrap" Margin="0,0,0,14"/>
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="稍后更新" Width="100" Height="38" Margin="0,0,8,0" IsCancel="True"/>
                <Button Content="下载并安装" Width="120" Height="38" IsDefault="True" Click="ConfirmButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
