<Window x:Class="NaiwaProxy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="NaiwaProxy" Height="720" Width="1100" MinHeight="640" MinWidth="980"
        Icon="assets/app-icon.ico"
        Background="#F4F6F8">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,14">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button x:Name="StartButton" Content="Start" Width="92" Height="34" Margin="0,0,8,0" Click="StartButton_Click"/>
                <Button x:Name="StopButton" Content="Stop" Width="92" Height="34" Margin="0,0,8,0" Click="StopButton_Click"/>
                <Button x:Name="EnableProxyButton" Content="Proxy On" Width="100" Height="34" Margin="0,0,8,0" Click="EnableProxyButton_Click"/>
                <Button x:Name="DisableProxyButton" Content="Proxy Off" Width="100" Height="34" Click="DisableProxyButton_Click"/>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="NaiwaProxy" FontSize="26" FontWeight="SemiBold" Foreground="#111827"/>
                <TextBlock x:Name="StatusText" Text="Idle" FontSize="13" Foreground="#4B5563" Margin="0,4,0,0"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#D8DEE6" BorderThickness="1" CornerRadius="6">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Profiles" FontSize="16" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,10"/>
                    <DataGrid x:Name="ProfilesGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False"
                              IsReadOnly="True" SelectionMode="Single" SelectionChanged="ProfilesGrid_SelectionChanged"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="*"/>
                            <DataGridTextColumn Header="Endpoint" Binding="{Binding Endpoint}" Width="145"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="New" Width="76" Height="30" Margin="0,0,8,0" Click="NewButton_Click"/>
                        <Button Content="Save" Width="76" Height="30" Margin="0,0,8,0" Click="SaveButton_Click"/>
                        <Button Content="Delete" Width="76" Height="30" Click="DeleteButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="White" BorderBrush="#D8DEE6" BorderThickness="1" CornerRadius="6">
                <TabControl>
                    <TabItem Header="Server">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center" Margin="0,0,8,10"/>
                                <TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Height="30" Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Address" VerticalAlignment="Center" Margin="0,0,8,10"/>
                                <TextBox x:Name="AddressBox" Grid.Row="1" Grid.Column="1" Height="30" Margin="0,0,12,10"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Port" VerticalAlignment="Center" Margin="0,0,8,10"/>
                                <TextBox x:Name="PortBox" Grid.Row="1" Grid.Column="3" Height="30" Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="UUID" VerticalAlignment="Center" Margin="0,0,8,10"/>
                                <TextBox x:Name="UuidBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Height="30" Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Alter ID" VerticalAlignment="Center" Margin="0,0,8,10"/>
                                <TextBox x:Name="AlterIdBox" Grid.Row="3" Grid.Column="1" Height="30" Margin="0,0,12,10"/>
                                <TextBlock Grid.Row="3" Grid.Column="2" Text="Security" VerticalAlignment="Center" Margin="0,0,8,10"/>
                                <ComboBox x:Name="SecurityBox" Grid.Row="3" Grid.Column="3" Height="30" Margin="0,0,0,10">
                                    <ComboBoxItem Content="auto"/>
                                    <ComboBoxItem Content="none"/>
                                    <ComboBoxItem Content="aes-128-gcm"/>
                                    <ComboBoxItem Content="chacha20-poly1305"/>
                                </ComboBox>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Network" VerticalAlignment="Center" Margin="0,0,8,10"/>
                                <ComboBox x:Name="NetworkBox" Grid.Row="4" Grid.Column="1" Height="30" Margin="0,0,12,10">
                                    <ComboBoxItem Content="tcp"/>
                                    <ComboBoxItem Content="ws"/>
                                </ComboBox>
                                <TextBlock Grid.Row="4" Grid.Column="2" Text="TLS" VerticalAlignment="Center" Margin="0,0,8,10"/>
                                <ComboBox x:Name="TlsBox" Grid.Row="4" Grid.Column="3" Height="30" Margin="0,0,0,10">
                                    <ComboBoxItem Content="none"/>
                                    <ComboBoxItem Content="tls"/>
                                </ComboBox>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Host" VerticalAlignment="Center" Margin="0,0,8,10"/>
                                <TextBox x:Name="HostBox" Grid.Row="5" Grid.Column="1" Height="30" Margin="0,0,12,10"/>
                                <TextBlock Grid.Row="5" Grid.Column="2" Text="SNI" VerticalAlignment="Center" Margin="0,0,8,10"/>
                                <TextBox x:Name="SniBox" Grid.Row="5" Grid.Column="3" Height="30" Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Path" VerticalAlignment="Center" Margin="0,0,8,10"/>
                                <TextBox x:Name="PathBox" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3" Height="30" Margin="0,0,0,10"/>

                                <Button Grid.Row="7" Grid.Column="1" Content="Save Profile" Width="130" Height="34" HorizontalAlignment="Left" Click="SaveButton_Click"/>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Import">
                        <Grid Margin="18">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="VMess sharing link" FontSize="15" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,10"/>
                            <TextBox x:Name="ImportBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                            <Button Grid.Row="2" Content="Import VMess" Width="130" Height="34" HorizontalAlignment="Left" Margin="0,12,0,0" Click="ImportButton_Click"/>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Runtime">
                        <Grid Margin="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="240"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="SOCKS Port" VerticalAlignment="Center" Margin="0,0,8,10"/>
                            <TextBox x:Name="SocksPortBox" Grid.Row="0" Grid.Column="1" Height="30" Margin="0,0,12,10"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="HTTP Port" VerticalAlignment="Center" Margin="0,0,8,10"/>
                            <TextBox x:Name="HttpPortBox" Grid.Row="0" Grid.Column="3" Height="30" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Core EXE" VerticalAlignment="Center" Margin="0,0,8,10"/>
                            <TextBox x:Name="CoreExeBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Height="30" Margin="0,0,0,10"/>

                            <Button Grid.Row="2" Grid.Column="1" Content="Save Runtime" Width="130" Height="34" HorizontalAlignment="Left" Click="SaveRuntimeButton_Click"/>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" Text="Core folder: application directory\cores. Generated config: %APPDATA%\NaiwaProxy\config.json"
                   Foreground="#6B7280" FontSize="12" Margin="0,12,0,0"/>
    </Grid>
</Window>
