                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Data="{StaticResource IconMail}" Style="{StaticResource AuthInputIconStyle}"/>
                                    <TextBox x:Name="RegisterEmailBox" Grid.Column="1" Height="42"/>
                                </Grid>
                                <TextBlock Style="{StaticResource AuthFieldLabelStyle}" Text="邮箱验证码"/>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Data="{StaticResource IconKey}" Style="{StaticResource AuthInputIconStyle}"/>
                                    <TextBox x:Name="RegisterCodeBox" Grid.Column="1" Height="42" Margin="0,0,10,0"/>
                                    <Button x:Name="SendRegisterCodeButton" Grid.Column="2" Content="发送验证码" Style="{StaticResource DarkButtonStyle}" MinWidth="120" Height="42" Click="SendRegisterCodeButton_Click"/>
                                </Grid>
                                <TextBlock Style="{StaticResource AuthFieldLabelStyle}" Text="密码"/>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Data="{StaticResource IconLock}" Style="{StaticResource AuthInputIconStyle}"/>
                                    <PasswordBox x:Name="RegisterPasswordBox" Grid.Column="1" Style="{StaticResource FieldPasswordBoxStyle}" Height="42"/>
                                </Grid>
                                <TextBlock Style="{StaticResource AuthFieldLabelStyle}" Text="确认密码"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Data="{StaticResource IconLock}" Style="{StaticResource AuthInputIconStyle}"/>
                                    <PasswordBox x:Name="RegisterConfirmPasswordBox" Grid.Column="1" Style="{StaticResource FieldPasswordBoxStyle}" Height="42"/>
                                </Grid>
                                <TextBlock Text="密码至少 8 位" Foreground="{StaticResource MutedBrush}" FontSize="14" Margin="30,0,0,12"/>
                                <TextBlock x:Name="RegisterMessageText" Foreground="{StaticResource RedBrush}" TextWrapping="Wrap" Margin="0,0,0,12" Visibility="Collapsed"/>
                                <Button x:Name="RegisterSubmitButton" Content="注册" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch" Height="46" Margin="0,4,0,18" Click="RegisterSubmitButton_Click"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="已有账号？" Foreground="{StaticResource MutedBrush}" FontSize="15" VerticalAlignment="Center"/>
                                    <Button Content="返回登录" Style="{StaticResource AuthLinkButtonStyle}" Margin="6,0,0,0" Click="GoToLoginPageButton_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
